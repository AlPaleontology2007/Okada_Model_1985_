def compute_los(UE, UN, UZ, inc_deg=38.0, heading_deg=-166.0):
    inc  = np.radians(inc_deg)
    head = np.radians(heading_deg)
    eE =  np.sin(inc) * np.sin(head)
    eN = -np.sin(inc) * np.cos(head)
    eZ =  np.cos(inc)
    return eE*UE + eN*UN + eZ*UZ

LOS = compute_los(UE, UN, UZ)

fig, ax = plt.subplots(1, 1, figsize=(6, 5))
fig.suptitle('LOS displacement (Sentinel-1, ascending)', fontsize=10)
im = ax.imshow(LOS, cmap='RdBu_r', origin='upper')
plt.colorbar(im, ax=ax, fraction=0.046, pad=0.04, label='m')
ax.set_title('LOS (m)')
ax.axis('off')
plt.tight_layout()
plt.savefig('okada_los.png', dpi=150, bbox_inches='tight')
plt.show()
