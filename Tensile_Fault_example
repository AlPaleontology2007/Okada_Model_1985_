# Depth of fault top edge (km)
# Shallow enough to cause surface deformation, deep enough to avoid singularities
depth = 10

# Strike angle from North (degrees)
# Full range of fault orientations
strike = 200 

# Dip angle (degrees)
# 0 = horizontal fault (unrealistic), 90 = vertical fault
# 15-90 covers all realistic fault types
dip = 70

# Fault length along strike (km)
# Small local faults to large regional faults
L = 15

# Fault width down dip (km)
# Always less than L, physically reasonable
W = 7

# Strike-slip component (m)
# Negative = right-lateral, positive = left-lateral
U1 = 0

# Dip-slip component (m)
# Negative = normal fault, positive = reverse fault
U2 = 0

# Tensile component (m)
# Always positive = opening crack, 0 = pure shear fault
# Much smaller than U1/U2 for tectonic faults
U3 = 1



# ── Grid ──────────────────────────────────────────────────────────

x_m = np.linspace(-30, 30, 224)
UE = np.zeros((224, 224))
UN = np.zeros((224, 224))
UZ = np.zeros((224, 224))

for i, n_val in enumerate(x_m):
    for j, e_val in enumerate(x_m):
        try:
            ue, un, uz = okada85(e_val, n_val, depth, strike, dip, L, W, U1, U2, U3)
            UE[i,j] = ue
            UN[i,j] = un
            UZ[i,j] = uz
        except:
            pass

